<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Forza HTTPS + www in un solo 301 (niente contenuti duplicati, niente loop)
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
  RewriteRule ^ https://www.%1%{REQUEST_URI} [R=301,L]

  # Fallback SPA: solo se non e' file/cartella esistente -> index.html
  # (cosi' i file prerenderizzati nelle sottocartelle, es. /servizi/medicina-legale/index.html,
  # vengono serviti direttamente come pagina statica, senza passare dal bundle JS)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# Nega l'accesso web ai file di servizio
<FilesMatch "^\.(htaccess|ftpquota)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml application/xml text/css application/javascript application/json application/ld+json
</IfModule>
